<?xml version="1.0" encoding="UTF-8"?>
<!--Id: c22b10a2-23f2-4980-9946-b33a2fe212bd -->
<OfficeApp 
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">
  
  <Id>c22b10a2-23f2-4980-9946-b33a2fe212bd</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Antigravity</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  
  <!-- The display name of the add-in in the Office Add-ins store and insertion lists. -->
  <DisplayName DefaultValue="Markdown Word" />
  <Description DefaultValue="Allows opening, editing, rendering, and saving Markdown (.md) documents natively in Microsoft Word for Mac." />
  
  <!-- Icons for the add-in. Since it's local host, we use our local assets. -->
  <IconUrl DefaultValue="https://davemen.github.io/MarkDownMac/assets/icon-32.png?v=2" />
  <HighResolutionIconUrl DefaultValue="https://davemen.github.io/MarkDownMac/assets/icon-80.png?v=2" />
  
  <SupportUrl DefaultValue="https://davemen.github.io/MarkDownMac/support.html" />
  
  <!-- Specify that this is a Document (Word) Add-in -->
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  
  <!-- Default location of the task pane web page -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://davemen.github.io/MarkDownMac/taskpane.html" />
  </DefaultSettings>
  
  <!-- Permissions needed by the add-in -->
  <Permissions>ReadWriteDocument</Permissions>
  
  <!-- Modern add-in ribbon commands and controls -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <!-- Function file is required for ribbon command execution, but for task pane it points to an empty HTML or similar, or we can use Task Pane directly -->
          <FunctionFile resid="Commands.Url" />
          
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <!-- Place the button in the standard Word Home Tab -->
            <OfficeTab id="TabHome">
              <Group id="MarkdownGroup">
                <Label resid="MarkdownGroup.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                
                <!-- Button 1: Toggle Task Pane -->
                <Control xsi:type="Button" id="OpenMarkdownBtn">
                  <Label resid="OpenMarkdownBtn.Label" />
                  <Supertip>
                    <Title resid="OpenMarkdownBtn.Label" />
                    <Description resid="OpenMarkdownBtn.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
                
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    
    <!-- String and Image Resources -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://davemen.github.io/MarkDownMac/assets/icon-16.png?v=2" />
        <bt:Image id="Icon.32x32" DefaultValue="https://davemen.github.io/MarkDownMac/assets/icon-32.png?v=2" />
        <bt:Image id="Icon.80x80" DefaultValue="https://davemen.github.io/MarkDownMac/assets/icon-80.png?v=2" />
      </bt:Images>
      
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://davemen.github.io/MarkDownMac/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://davemen.github.io/MarkDownMac/taskpane.html" />
      </bt:Urls>
      
      <bt:ShortStrings>
        <bt:String id="MarkdownTab.Label" DefaultValue="Markdown" />
        <bt:String id="MarkdownGroup.Label" DefaultValue="Markdown Tools" />
        <bt:String id="OpenMarkdownBtn.Label" DefaultValue="Markdown Panel" />
      </bt:ShortStrings>
      
      <bt:LongStrings>
        <bt:String id="OpenMarkdownBtn.Tooltip" DefaultValue="Open the Markdown converter and manager panel." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
